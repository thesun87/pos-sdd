{
  "name": "@pos-sdd/database",
  "version": "0.1.0",
  "private": true,
  "description": "Database package with Prisma client for pos-sdd monorepo",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf dist",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@pos-sdd/config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
